EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
EXPO_PUBLIC_STRIPE_PRICE_STARTER=
EXPO_PUBLIC_STRIPE_PRICE_PRO=
EXPO_PUBLIC_STRIPE_PRICE_PREMIUM=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Wallet API (serveur uniquement - ne pas préfixer EXPO_PUBLIC_)
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=
GOOGLE_WALLET_PRIVATE_KEY=
# Comment obtenir ces valeurs :
# 1. Créer un compte Issuer : https://pay.google.com/business/console
# 2. Créer un projet Google Cloud : https://console.cloud.google.com
# 3. Activer l'API Google Wallet dans le projet Cloud
# 4. Créer un compte de service (IAM > Service accounts)
# 5. Télécharger la clé JSON du compte de service
# 6. GOOGLE_WALLET_ISSUER_ID = le chiffre long dans l'URL de la console Wallet
# 7. GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL = client_email dans le JSON de la clé
# 8. GOOGLE_WALLET_PRIVATE_KEY = private_key dans le JSON (garder les \n)
# 9. Autoriser le compte de service : console Wallet > Utilisateurs > ajouter
#    le service account avec le rôle "Writer"
# 10. Déployer les secrets : supabase secrets set GOOGLE_WALLET_ISSUER_ID=...

# Validation des commerçants + emails (serveur uniquement)
# Adresse qui reçoit l'alerte à chaque inscription commerçant.
ADMIN_EMAIL=
# Resend (https://resend.com) pour les emails transactionnels (admin + commerçants).
RESEND_API_KEY=
# Expéditeur vérifié dans Resend, ex : "Fidéli <no-reply@tondomaine.fr>"
RESEND_FROM=
# Déploiement des secrets :
#   supabase secrets set ADMIN_EMAIL=ton@email.com
#   supabase secrets set RESEND_API_KEY=re_xxx
#   supabase secrets set RESEND_FROM="Fidéli <no-reply@tondomaine.fr>"
# Puis déployer les functions :
#   supabase functions deploy notify-merchant-signup
#   supabase functions deploy approve-merchant
#   supabase functions deploy reject-merchant

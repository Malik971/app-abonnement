{
  "expo": {
    "name": "Fidéli",
    "slug": "fidelite-guadeloupe",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fidelite",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/brand/app_icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fidelite.guadeloupe",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "L'accès à la caméra permet de scanner le QR code en caisse pour cumuler vos points de fidélité.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.fidelite.guadeloupe",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/app_icon.png",
        "backgroundColor": "#D62828"
      },
      "permissions": [
        "CAMERA",
        "NOTIFICATIONS",
        "com.google.android.gms.permission.LOYALTY_PROGRAM"
      ],
      "intentFilters": [],
      "queries": {
        "intents": [
          {
            "action": "android.intent.action.VIEW",
            "data": {
              "scheme": "https",
              "host": "pay.google.com"
            }
          }
        ]
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/logo_blanc_splash.png",
          "backgroundColor": "#D62828",
          "resizeMode": "contain",
          "imageWidth": 220
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "L'accès à la caméra permet de scanner le QR code en caisse pour cumuler vos points de fidélité."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#D62828"
        }
      ],
      "expo-asset",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.REMPLACER_PAR_REVERSED_CLIENT_ID"
        }
      ],
      [
        "react-native-fbsdk-next",
        {
          "appID": "REMPLACER_FB_APP_ID",
          "clientToken": "REMPLACER_FB_CLIENT_TOKEN",
          "displayName": "Fidéli",
          "scheme": "fbREMPLACER_FB_APP_ID"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
